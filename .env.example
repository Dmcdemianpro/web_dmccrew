# Deploy Hook URL (opcional)
# Obtener desde tu plataforma de hosting:
# - Vercel: Project Settings > Git > Deploy Hooks
# - Netlify: Site settings > Build & deploy > Build hooks
# - Render: Settings > Deploy Hooks

DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxxxx/xxxxx

# =====================================================
# CONFIGURACION DE EMAIL (para formulario de contacto)
# =====================================================
# Si no se configuran estas variables, los mensajes se
# registran en la consola del servidor (modo desarrollo)

# Email destinatario (donde llegan los mensajes de contacto)
CONTACT_EMAIL=contacto@dmcprojects.cl

# Configuracion SMTP
# Ejemplos para diferentes proveedores:
#
# Gmail (requiere App Password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=tu-email@gmail.com
#   SMTP_PASS=tu-app-password
#
# Outlook/Hotmail:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASS=tu-sendgrid-api-key
#
# Mailgun:
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
#   SMTP_SECURE=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# =====================================================
# DIRECTORIO DE DATOS (para VPS/servidor propio)
# =====================================================
# Ruta donde se almacenan los archivos JSON y uploads
# Si no se configura, usa el directorio 'data' del proyecto

# DATA_DIR=/var/www/dmcprojects/data
